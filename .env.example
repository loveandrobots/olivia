# ─── Docker Compose runtime variables ───────────────────────────────────────
# Copy this file to .env on the EC2 server and fill in the values.
# The .env file is read automatically by docker compose.

# The GitHub username or org that owns this repository.
# Used to reference images in ghcr.io.
# Example: octocat
GITHUB_REPOSITORY_OWNER=

# The Tailscale hostname or IP of this EC2 instance.
# Used to set the API's OLIVIA_PWA_ORIGIN so logs show the correct origin.
# Example: 100.64.0.5  or  my-ec2.tailnet-name.ts.net
EC2_TAILSCALE_HOST=

# GitHub Classic Personal Access Token with read:packages scope.
# Used by the deploy script to pull images from GHCR.
# NOTE: Must be a Classic token — fine-grained PATs do not support read:packages.
# Generate at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
GHCR_TOKEN=

# ─── Anthropic API (optional) ────────────────────────────────────────────────
# API key for Anthropic Claude integration.
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Push Notifications (optional) ──────────────────────────────────────────
# Set OLIVIA_NOTIFICATIONS_ENABLED=true and provide VAPID keys to enable
# web push notifications. Generate keys with:
#   npx web-push generate-vapid-keys
OLIVIA_NOTIFICATIONS_ENABLED=false
OLIVIA_VAPID_PUBLIC_KEY=
OLIVIA_VAPID_PRIVATE_KEY=
# Must be a mailto: or https: URI identifying the notification sender.
OLIVIA_VAPID_CONTACT=mailto:admin@localhost

# How often the notification scheduler runs (milliseconds). Default: 1 hour.
OLIVIA_NOTIFICATION_INTERVAL_MS=3600000

# ─── Business logic tuning (optional, defaults shown) ───────────────────────
# How many days before an item is considered stale.
OLIVIA_STALE_THRESHOLD_DAYS=14
# How many days ahead to flag items as due soon.
OLIVIA_DUE_SOON_DAYS=7

# ─── Notification rules (optional, all default to false) ────────────────────
OLIVIA_NOTIFY_DUE_SOON=false
OLIVIA_NOTIFY_STALE_ITEM=false
OLIVIA_NOTIFY_DIGEST=false
